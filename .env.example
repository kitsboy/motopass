# Copy to .env.local for local development (never commit secrets)

# Cloudflare — required for manual wrangler deploys: npx wrangler pages deploy dist/
# Create token at https://dash.cloudflare.com/profile/api-tokens
# Permissions: Account / Cloudflare Pages / Edit
CLOUDFLARE_API_TOKEN=

# Optional overrides
VITE_SITE_URL=https://motopass.giveabit.io
VITE_SATOHASH_URL=https://satohash.io
VITE_NOSTR_RELAY=wss://relay.motopass.giveabit.io
VITE_BTCMAP_API_URL=https://api.btcmap.org
VITE_BTCMAP_WEB_URL=https://btcmap.org